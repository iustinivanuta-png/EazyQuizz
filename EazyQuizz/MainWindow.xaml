<Window x:Class="EazyQuizz.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EazyQuizz"
        Height="650"
        Width="950"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <TabControl>

            <TabItem Header="Autentificare">

                <Grid>

                    <Border Width="400"
                            Padding="30"
                            CornerRadius="8"
                            BorderBrush="#CCCCCC"
                            BorderThickness="1"
                            Background="#FAFAFA"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                        <StackPanel>

                            <TextBlock Text="Nume student:"
                                       FontSize="14"
                                       Margin="0,0,0,5"/>

                            <TextBox x:Name="txtStudentName"
                                     Height="30"
                                     Margin="0,0,0,15"/>

                            <TextBlock Text="Parola:"
                                       FontSize="14"
                                       Margin="0,0,0,5"/>

                            <PasswordBox x:Name="txtPassword"
                                         Height="30"
                                         Margin="0,0,0,20"/>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">

                                <Button Content="Inregistrare"
                                        Width="120"
                                        Height="35"
                                        Margin="5"
                                        Click="Register_Click"/>

                                <Button Content="Login"
                                        Width="120"
                                        Height="35"
                                        Margin="5"
                                        Click="Login_Click"/>

                            </StackPanel>

                            <TextBlock x:Name="txtLoginStatus"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Margin="0,20,0,0"
                                       HorizontalAlignment="Center"/>

                        </StackPanel>

                    </Border>

                </Grid>

            </TabItem>

            <TabItem Header="Quiz">

                <Grid Margin="20">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">

                        <TextBlock Text="Domeniu:"
                                   VerticalAlignment="Center"/>

                        <ComboBox x:Name="cbQuizDomain"
                                  Width="150"
                                  Margin="10"
                                  ItemsSource="{Binding DomainItems}"/>

                        <Button Content="Start Quiz"
                                Width="120"
                                Click="StartQuiz_Click"/>

                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,20">

                        <TextBlock x:Name="txtQuestion"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"/>

                        <Image x:Name="imgQuestion"
                               Height="180"
                               Margin="0,10"
                               Stretch="Uniform"/>

                        <RadioButton x:Name="rb1"
                                     GroupName="answers"
                                     Margin="5"/>

                        <RadioButton x:Name="rb2"
                                     GroupName="answers"
                                     Margin="5"/>

                        <RadioButton x:Name="rb3"
                                     GroupName="answers"
                                     Margin="5"/>

                        <RadioButton x:Name="rb4"
                                     GroupName="answers"
                                     Margin="5"/>

                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal">

                        <Button Content="Raspunde"
                                Width="120"
                                Margin="5"
                                Click="Answer_Click"/>

                        <TextBlock x:Name="txtQuizStatus"
                                   Margin="20,10"
                                   FontWeight="Bold"/>

                    </StackPanel>

                </Grid>

            </TabItem>

            <TabItem Header="Administrare intrebari">

                <Grid Margin="20">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>

                        <TextBox x:Name="txtSearch"
                                 Margin="0,0,0,10"/>

                        <Button Content="Cauta dupa text"
                                Margin="0,0,0,10"
                                Click="Search_Click"/>

                        <ListBox x:Name="lstQuestions"
                                 ItemsSource="{Binding Questions}"
                                 DisplayMemberPath="text"
                                 Height="450"
                                 SelectionChanged="lstQuestions_SelectionChanged"/>

                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="20,0">

                        <TextBlock Text="Text intrebare:"/>
                        <TextBox x:Name="txtQuestionAdmin" Margin="0,5"/>

                        <TextBlock Text="Domeniu:"/>
                        <ComboBox x:Name="cbDomain"
                                  ItemsSource="{Binding DomainItems}"
                                  Margin="0,5"/>

                        <TextBlock Text="Dificultate:"/>
                        <ComboBox x:Name="cbDifficulty"
                                  ItemsSource="{Binding DifficultyItems}"
                                  Margin="0,5"/>

                        <CheckBox x:Name="chkImage"
                                  Content="Intrebarea contine imagine"
                                  Margin="0,5"/>

                        <TextBox x:Name="txtImagePath"
                                 Margin="0,5"/>

                        <CheckBox x:Name="chkMultiple"
                                  Content="Raspuns multiplu"
                                  Margin="0,5"/>

                        <TextBlock Text="Raspunsuri:"
                                   FontWeight="Bold"
                                   Margin="0,10"/>

                        <TextBox x:Name="txtA1" Margin="0,3"/>
                        <RadioButton x:Name="correct1"
                                     GroupName="correct"
                                     Content="Corect"/>

                        <TextBox x:Name="txtA2" Margin="0,3"/>
                        <RadioButton x:Name="correct2"
                                     GroupName="correct"
                                     Content="Corect"/>

                        <TextBox x:Name="txtA3" Margin="0,3"/>
                        <RadioButton x:Name="correct3"
                                     GroupName="correct"
                                     Content="Corect"/>

                        <TextBox x:Name="txtA4" Margin="0,3"/>
                        <RadioButton x:Name="correct4"
                                     GroupName="correct"
                                     Content="Corect"/>

                        <StackPanel Orientation="Horizontal" Margin="0,15">

                            <Button Content="Adauga"
                                    Width="100"
                                    Margin="5"
                                    Click="AddQuestion_Click"/>

                            <Button Content="Modifica"
                                    Width="100"
                                    Margin="5"
                                    Click="UpdateQuestion_Click"/>

                            <Button Content="Sterge"
                                    Width="100"
                                    Margin="5"
                                    Click="DeleteQuestion_Click"/>

                            <Button Content="Salveaza"
                                    Width="100"
                                    Margin="5"
                                    Click="SaveQuestions_Click"/>

                        </StackPanel>

                    </StackPanel>

                </Grid>

            </TabItem>

            <TabItem Header="Scoruri">

                <StackPanel Margin="20">

                    <Button Content="Incarca scoruri"
                            Width="150"
                            Click="LoadScores_Click"/>

                    <ListBox x:Name="lstScores"
                             Margin="0,10"
                             Height="450"/>

                </StackPanel>

            </TabItem>

        </TabControl>

    </Grid>
</Window>